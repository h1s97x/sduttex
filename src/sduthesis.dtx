%%
%% ===================================================================
%% Cover Page
%% ===================================================================
%%
%% \subsection{Cover Page}
%%
%% Layout constants.
%%    \begin{macrocode}
%<!CLASS>
\dim_gset:Nn \g_@@_cover_label_width_dim { 2.3cm }
\dim_gset:Nn \g_@@_cover_value_width_dim { 5.5cm }
%    \end{macrocode}
%%
%% Cover table entry.
%%    \begin{macrocode}
%<!CLASS>
\cs_new:Npn \@@_cover_entry:nn #1#2 {
  \begin{tabular}{p{\g_@@_cover_label_width_dim}p{\g_@@_cover_value_width_dim}}
    \centering \zihao{3} \bfseries \kaishu {#1} &
    \centering \zihao{3} \kaishu {#2}
    \\ \cline{2-2}
  \end{tabular}
  \vspace{-5mm}
}
%    \end{macrocode}
%%
%% Bachelor cover page.
%%    \begin{macrocode}
%<!CLASS>
\cs_new:Npn \@@_make_cover_bachelor: {
  \begin{titlepage}
    \begin{center}
      \vspace*{5mm}

      % University logo
      \includegraphics[width=0.7\textwidth]{logos/sdu_logo}

      \vspace*{10mm}

      % Title image
      \includegraphics[width=0.95\textwidth]{logos/sdu_title}

      \vspace*{5mm}

      % Thesis title label
      \begin{flushleft}
        \zihao{3} \bfseries \fangsong {论\qquad 文\qquad 题\qquad 目：}
      \end{flushleft}

      % Thesis title
      \begin{minipage}{\dim_eval:n { 0.9 \textwidth }}
        \centering \zihao{2} \bfseries \hei { \GetTitle }
      \end{minipage}

      \vspace*{30mm}

      % Information table
      \@@_cover_entry:nn { 姓\qquad 名 } { \@@_secret_info:n { \GetAuthor } }
      \@@_cover_entry:nn { 学\qquad 号 } { \@@_secret_info_fixed:Nn \g_@@_student_id_tl { 10 } }
      \@@_cover_entry:nn { 学\qquad 院 } { \GetSchool }
      \@@_cover_entry:nn { 专\qquad 业 } { \GetMajor }
      \@@_cover_entry:nn { 指\ 导\ 教\ 师 } { \@@_secret_info:n { \GetSupervisor } }

      \vspace*{35mm}

      % Date
      \zihao{3} \kaishu { \GetDate }
    \end{center}
  \end{titlepage}
}
%    \end{macrocode}
%%
%% Graduate cover page (master/doctor).
%%    \begin{macrocode}
%<!CLASS>
\cs_new:Npn \@@_make_cover_graduate: {
  \begin{titlepage}
    \begin{center}
      \vspace*{5mm}

      % University logo
      \includegraphics[width=0.7\textwidth]{logos/sdu_logo}

      \vspace*{10mm}

      % Title image
      \includegraphics[width=0.95\textwidth]{logos/sdu_title}

      \vspace*{10mm}

      % Thesis type
      \@@_if_type_professional:TF {
        \zihao{2} \bfseries \hei { 专业学位（硕士/博士）论文 }
      } {
        \zihao{2} \bfseries \hei { 学术学位（硕士/博士）论文 }
      }

      \vspace*{10mm}

      % Chinese title
      \begin{minipage}{\dim_eval:n { 0.9 \textwidth }}
        \centering \zihao{2} \bfseries \hei { \GetTitle }
      \end{minipage}

      \vspace*{8mm}

      % English title
      \begin{minipage}{\dim_eval:n { 0.9 \textwidth }}
        \centering \zihao{4} \hei { \GetTitleEn }
      \end{minipage}

      \vspace*{15mm}

      % Author info
      \@@_cover_entry:nn { 研究生姓名 } { \@@_secret_info:n { \GetAuthor } }
      \@@_cover_entry:nn { 学科专业 } { \GetMajor }
      \@@_cover_entry:nn { 指导教师 } { \@@_secret_info:n { \GetSupervisor } \，
                                           \GetSupervisorTitle }
      \bool_if:NT \g_@@_co_supervisor_tl {
        \@@_cover_entry:nn { 合作指导教师 } { \@@_secret_info:n { \GetCoSupervisor } }
      }

      \vspace*{20mm}

      % Date
      \zihao{3} \kaishu { \GetDate }
    \end{center}
  \end{titlepage}
}
%    \end{macrocode}
%%
%% \begin{function}{\MakeCover}
%% Generate the cover page.
%%    \begin{macrocode}
%<!CLASS>
\NewDocumentCommand \MakeCover { } {
  \@@_if_type_bachelor:TF {
    \@@_make_cover_bachelor:
  } {
    \@@_make_cover_graduate:
  }
}
%    \end{macrocode}
%% \end{function}

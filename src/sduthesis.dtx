%%
%% ===================================================================
%% Auxiliary Functions
%% ===================================================================
%%
%% \subsection{Auxiliary Functions}
%%
%% \begin{function}{\@@_if_type_bachelor:TF}
%% 判断是否为本科生
%%    \begin{macrocode}
%<!CLASS>
\cs_new:Npn \@@_if_type_bachelor:TF #1#2 {
  \int_compare:nNnTF {\g_@@_type_int} = {1} {#1} {#2}
}
%    \end{macrocode}
%% \end{function}
%%
%% \begin{function}{\@@_if_type_master:TF}
%% 判断是否为硕士
%%    \begin{macrocode}
%<!CLASS>
\cs_new:Npn \@@_if_type_master:TF #1#2 {
  \int_compare:nNnTF {1} < {\g_@@_type_int} { \int_compare:nNnTF {4} > {\g_@@_type_int} {#1} {#2} } {#2}
}
%    \end{macrocode}
%% \end{function}
%%
%% \begin{function}{\@@_if_type_doctor:TF}
%% 判断是否为博士
%%    \begin{macrocode}
%<!CLASS>
\cs_new:Npn \@@_if_type_doctor:TF #1#2 {
  \int_compare:nNnTF {\g_@@_type_int} = {4} {#1} {#2}
}
%    \end{macrocode}
%% \end{function}
%%
%% \begin{function}{\@@_if_type_professional:TF}
%% 判断是否为专业型
%%    \begin{macrocode}
%<!CLASS>
\cs_new:Npn \@@_if_type_professional:TF #1#2 {
  \int_compare:nNnTF {\g_@@_type_int} = {3} {#1} {#2}
}
%    \end{macrocode}
%% \end{function}
%%
%% \begin{function}{\@@_if_blind:TF}
%% 判断是否为盲审模式
%%    \begin{macrocode}
%<!CLASS>
\cs_new:Npn \@@_if_blind:TF #1#2 {
  \bool_if:NTF \g_@@_blind_bool {#1} {#2}
}
%    \end{macrocode}
%% \end{function}
%%
%% \begin{function}{\@@_secret_info:n}
%% 隐藏敏感信息（用于盲审）
%%    \begin{macrocode}
%<!CLASS>
\cs_new:Npn \@@_secret_info:n #1 {
  \@@_if_blind:TF {
    \leavevmode\CJKcircle { 1 }
  } {
    #1
  }
}
%    \end{macrocode}
%% \end{function}
%%
%% \begin{function}{\@@_secret_info_fixed:Nn}
%% 固定长度隐藏（用于学号等）
%%    \begin{macrocode}
%<!CLASS>
\cs_new:Npn \@@_secret_info_fixed:Nn #1#2 {
  \tl_if_blank:VTF #1 { } {
    \@@_if_blind:TF {
      \prg_replicate:nn {#2} { \CJKcircle { 1 } }
    } {
      #1
    }
  }
}
%    \end{macrocode}
%% \end{function}

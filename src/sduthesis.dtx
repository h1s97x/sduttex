%%
%% ===================================================================
%% Page Layout
%% ===================================================================
%%
%% \subsection{Page Layout}
%%
%% Set page geometry.
%%    \begin{macrocode}
%<!CLASS>
\geometry {
  top = 3.0cm,
  bottom = 2.5cm,
  left = 3.0cm,
  right = 2.5cm,
  headheight = 1.5cm,
  headsep = 0.5cm,
  footskip = 1.0cm
}
%    \end{macrocode}
%%
%% ===================================================================
%% Style Configuration
%% ===================================================================
%%
%% \subsection{Style Configuration}
%%
%% Set Chinese font (using system fonts).
%%    \begin{macrocode}
%<!CLASS>
\setmainfont{Times~New~Roman}[AutoFakeBold]
\setsansfont{Arial}
\setmonofont{Consolas}
%    \end{macrocode}
%%
%% Set bibliography style.
%%    \begin{macrocode}
%<!CLASS>
\RequirePackage[sort&compress]{gbt7714}
\ bibliographystyle{gbt7714-numerical}
%    \end{macrocode}
%%
%% Set algorithm style.
%%    \begin{macrocode}
%<!CLASS>
\RequirePackage { algpseudocode }
%    \end{macrocode}
%%
%% ===================================================================
%% User Setup Interface
%% ===================================================================
%%
%% \subsection{User Setup Interface}
%%
%% Define setup keys.
%%    \begin{macrocode}
%<!CLASS>
\keys_define:nn { sdu / setup } {
  title .tl_gset:N = \g_@@_title_tl,
  title* .tl_gset:N = \g_@@_title_en_tl,
  author .tl_gset:N = \g_@@_author_tl,
  student-id .tl_gset:N = \g_@@_student_id_tl,
  major .tl_gset:N = \g_@@_major_tl,
  department .tl_gset:N = \g_@@_department_tl,
  supervisor .tl_gset:N = \g_@@_supervisor_tl,
  supervisor-title .tl_gset:N = \g_@@_supervisor_title_tl,
  co-supervisor .tl_gset:N = \g_@@_co_supervisor_tl,
  date .tl_gset:N = \g_@@_date_tl,
  keywords .tl_gset:N = \g_@@_keywords_tl,
  keywords* .tl_gset:N = \g_@@_keywords_en_tl,
}
%    \end{macrocode}
%%
%% \begin{function}{\SDUSetup}
%% Main setup command for users.
%%    \begin{macrocode}
%<!CLASS>
\NewDocumentCommand \SDUSetup { m } {
  \keys_set:nn { sdu / setup } {#1}
}
%    \end{macrocode}
%% \end{function}
%%
%% ===================================================================
%% Cover Page Commands
%% ===================================================================
%%
%% \subsection{Cover Page Commands}
%%
%% \begin{function}{\MakeCover}
%% Generate the cover page.
%%    \begin{macrocode}
%<!CLASS>
\NewDocumentCommand \MakeCover { } {
  \begin{titlepage}
    \centering
    \vspace*{1cm}
    {\heiti\zihao{1}\SDUSetupTitle\par}
    \vspace{2cm}
    % Cover content will be defined in separate files
  \end{titlepage}
}
%    \end{macrocode}
%% \end{function}
%%
%% ===================================================================
%% Section Style
%% ===================================================================
%%
%% \subsection{Section Style}
%%
%% Configure section headings.
%%    \begin{macrocode}
%<!CLASS>
\ctexset {
  chapter = {
    format = { \heiti \bfseries \centering \zihao{3} },
    beforeskip = { 0pt },
    afterskip = { 18pt },
    number = { \thechapter }
  },
  section = {
    format = { \heiti \bfseries \zihao{4} },
    beforeskip = { 18pt },
    afterskip = { 12pt }
  },
  subsection = {
    format = { \kaishu \bfseries \zihao{-4} },
    beforeskip = { 12pt },
    afterskip = { 6pt }
  }
}
%    \end{macrocode}
%%
%% ===================================================================
%% Header and Footer
%% ===================================================================
%%
%% \subsection{Header and Footer}
%%
%% Configure header and footer.
%%    \begin{macrocode}
%<!CLASS>
\fancypagestyle{plain}{
  \fancyhf{}
  \fancyfoot[C]{\thepage}
  \renewcommand{\headrulewidth}{0pt}
}

\pagestyle{plain}
%    \end{macrocode}

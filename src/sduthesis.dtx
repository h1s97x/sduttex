%%
%% ===================================================================
%% Global Variables
%% ===================================================================
%%
%% \subsection{Global Variables}
%%
%% \begin{variable}{\g_@@_type_int}
%% 论文类型：
%% \begin{itemize}
%%   \item 1 = bachelor (本科生)
%%   \item 2 = master (学术型硕士)
%%   \item 3 = master-professional (专业型硕士)
%%   \item 4 = doctor (博士)
%% \end{itemize}
%%    \begin{macrocode}
%<!CLASS>
\int_new:N \g_@@_type_int
%    \end{macrocode}
%% \end{variable}
%%
%% \begin{variable}{\g_@@_blind_bool}
%% 是否为盲审模式
%%    \begin{macrocode}
%<!CLASS>
\bool_new:N \g_@@_blind_bool
%    \end{macrocode}
%% \end{variable}
%%
%% \begin{variable}{\g_@@_twoside_bool}
%% 是否双面打印
%%    \begin{macrocode}
%<!CLASS>
\bool_new:N \g_@@_twoside_bool
%    \end{macrocode}
%% \end{variable}
%%
%% User configuration variables.
%%    \begin{macrocode}
%<!CLASS>
\tl_new:N \g_@@_title_tl
\tl_new:N \g_@@_title_en_tl
\tl_new:N \g_@@_author_tl
\tl_new:N \g_@@_student_id_tl
\tl_new:N \g_@@_major_tl
\tl_new:N \g_@@_department_tl
\tl_new:N \g_@@_supervisor_tl
\tl_new:N \g_@@_supervisor_title_tl
\tl_new:N \g_@@_co_supervisor_tl
\tl_new:N \g_@@_date_tl
\tl_new:N \g_@@_keywords_tl
\tl_new:N \g_@@_keywords_en_tl
%    \end{macrocode}
%%
%% ===================================================================
%% Auxiliary Functions
%% ===================================================================
%%
%% \subsection{Auxiliary Functions}
%%
%% \begin{function}{\@@_if_type_bachelor:TF}
%% 判断是否为本科生
%%    \begin{macrocode}
%<!CLASS>
\cs_new:Npn \@@_if_type_bachelor:TF #1#2 {
  \int_compare:nNnTF {\g_@@_type_int} = {1} {#1} {#2}
}
%    \end{macrocode}
%% \end{function}
%%
%% \begin{function}{\@@_if_type_graduate:TF}
%% 判断是否为研究生（硕士或博士）
%%    \begin{macrocode}
%<!CLASS>
\cs_new:Npn \@@_if_type_graduate:TF #1#2 {
  \int_compare:nNnTF {1} < {\g_@@_type_int} {#1} {#2}
}
%    \end{macrocode}
%% \end{function}
%%
%% \begin{function}{\@@_if_blind:TF}
%% 判断是否为盲审模式
%%    \begin{macrocode}
%<!CLASS>
\cs_new:Npn \@@_if_blind:TF #1#2 {
  \bool_if:NTF \g_@@_blind_bool {#1} {#2}
}
%    \end{macrocode}
%% \end{function}
%%
%% \begin{function}{\@@_secret_info:n}
%% 隐藏敏感信息（用于盲审）
%%    \begin{macrocode}
%<!CLASS>
\cs_new:Npn \@@_secret_info:n #1 {
  \@@_if_blind:TF {
    \prg_replicate:nn { \tl_count:n {#1} } { $\square$ }
  } {
    #1
  }
}
%    \end{macrocode}
%% \end{function}
%%
%% ===================================================================
%% Options Parsing
%% ===================================================================
%%
%% \subsection{Options Parsing}
%%
%% Declare class options.
%%    \begin{macrocode}
%<!CLASS>
\keys_define:nn { sdu / option } {
  degree .choice:,
  degree .value_required:n = true,
  degree / bachelor .code:n = {
    \int_gset:Nn \g_@@_type_int {1}
  },
  degree / master .code:n = {
    \int_gset:Nn \g_@@_type_int {2}
  },
  degree / master-professional .code:n = {
    \int_gset:Nn \g_@@_type_int {3}
  },
  degree / doctor .code:n = {
    \int_gset:Nn \g_@@_type_int {4}
  },
  blind .bool_set:N = \g_@@_blind_bool,
  blind .initial:n = {false},
  twoside .bool_set:N = \g_@@_twoside_bool,
  twoside .initial:n = {false},
  unknown .code:n = {
    \PassOptionsToClass {\l_keys_key_tl} {ctexbook}
  }
}
%    \end{macrocode}
%%
%% Process options.
%%    \begin{macrocode}
%<!CLASS>
\ProcessKeysOptions { sdu / option }
%    \end{macrocode}
